{
  "projectType": "api-service",
  "projectName": "Fisioterapia Backend API",
  "projectDescription": "REST API for managing physiotherapy appointments, patients, therapists, and user authentication",
  "theme": "palm",
  "primaryColor": "#3B82F6",
  "lightColor": "#60A5FA",
  "darkColor": "#1E40AF",
