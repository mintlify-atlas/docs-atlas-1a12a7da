  "keyFeatures": [
    "Appointment scheduling and management",
    "User authentication with JWT and social login (Google/Facebook)",
    "Role-based access control (Admin, Physiotherapist, Patient)",
    "Patient medical history tracking",
    "Physiotherapist specialty filtering",
    "MongoDB data persistence with Mongoose",
    "Firebase Admin integration"
  ],
  "publicApiSurface": [
    "POST /auth/login",
    "POST /auth/login-social",
    "GET /auth/facebook",
    "POST /api/user",
    "GET /api/user",
    "GET /api/user/find",
    "GET /api/user/getdni/:dni",
    "POST /api/paciente",
    "GET /api/paciente",
    "POST /api/paciente/update-paciente/:id",
    "POST /api/fisioterapeuta",
    "GET /api/fisioterapeuta",
    "GET /api/fisioterapeuta/:id",
    "GET /api/fisioterapeuta/especialidad/:espe",
    "POST /api/cita",
    "GET /api/cita",
    "GET /api/cita/:id",
    "GET /api/cita/paciente/:id",
    "PUT /api/cita/update/:id",
    "DELETE /api/cita/delete/:id",
    "POST /api/admin",
    "POST /api/contacto"
  ]
}
