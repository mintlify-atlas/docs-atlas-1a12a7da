          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "authentication"]
          },
          {
            "group": "Core Concepts",
            "pages": ["concepts/architecture", "concepts/data-models", "concepts/user-roles"]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/setup-environment",
              "guides/managing-appointments",
              "guides/user-management",
              "guides/social-authentication"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
